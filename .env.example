# Dateirechte der persistenten Host-Verzeichnisse.
# Auf typischen Ubuntu-Systemen gehört der erste Benutzer UID/GID 1000.
PUID=1000
PGID=1000

# Sensibler bzw. personenbezogener Wert: 64-Bit-Steam-ID des Administrators.
# Platzhalter unbedingt ersetzen. Keine Steam-Anmeldeinformationen eintragen.
ADMIN_STEAM_ID=76561198000000000

# Galaxie und Server
GALAXY_NAME=avorion_galaxy
SERVER_NAME=Mein Avorion Server
SERVER_PORT=27000
MAX_PLAYERS=10
SAVE_INTERVAL=300
DIFFICULTY=0

# Leer lassen, damit Avorion die Thread-Einstellung selbst bzw. aus server.ini übernimmt.
SERVER_THREADS=

# 1 = aktiviert, 0 = deaktiviert
PUBLIC=1
LISTED=1
USE_STEAM_NETWORKING=1

# SteamCMD
UPDATE_ON_START=true
VALIDATE_ON_START=false

# Leer = stabiler Standard-Branch; für den Beta-Branch z. B. "beta" setzen.
STEAM_BRANCH=

# Geordnetes Herunterfahren
SHUTDOWN_SAVE_WAIT=10
SHUTDOWN_TIMEOUT=120

# Zusätzliche Argumente, durch Leerzeichen getrennt; keine Werte mit Leerzeichen verwenden.
# Beispiel: --same-start-sector 1 --collision-damage 0.5
EXTRA_SERVER_ARGS=
